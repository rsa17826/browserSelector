{
  "$schema": "./settings.schema.jsonc",
  "settings": {
    "closeOnFocusLoss": false,
    "defaultBrowser": "",
    "closeOnEscPressed": true,
    "hideEmptyProperties": true,
    "alwaysOnTop": false
  },
  "programs": {
    "__default__": {
      "path": "__default__",
      "args": ["$url"]
    },
    "brave": {
      "path": "brave",
      "args": ["$url"]
    },
    "copy": {
      "path": "sh",
      "args": [
        "-c",
        "wl-copy '$url' && notify-send -t 2000 'Copied: $url'"
      ]
    },
    "notify": {
      "path": "notify-send",
      "args": ["$url"]
    }
  },
  "rules": [
    {
      "matches": [["fulldomain", "is", "test"]],
      "name": "a"
    },
    {
      "name": "brave",
      "matches": [
        ["protocol", "is", "https"],
        ["fulldomain", "is", "github.com"],
        ["path", "matchesregex", "^/([^/]+/){2}issues/\\d+\\/?$"]
      ]
    },
    {
      "name": "brave",
      "matches": [["url", "is", "http://127.0.0.1:8384/"]]
    },
    {
      "name": "copy",
      "matches": [
        [
          "parentprocesscmdline",
          "is",
          "/home/nyix/.local/share/Steam/ubuntu12_32/steam -srt-logger-opened"
        ]
      ]
    }
  ]
}
